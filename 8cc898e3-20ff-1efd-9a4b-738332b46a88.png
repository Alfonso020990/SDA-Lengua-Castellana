          <htmlView><![CDATA[<div class="exe-text-template">
    <p style="text-align: justify;"><strong>8. CRITERIOS DE EVALUACIÓN</strong></p>
<p style="text-align: justify;"><br />¿Qué se evaluará?</p>
<ol>
<li style="text-align: justify;">Comprensión lectora</li>
<li style="text-align: justify;">Identifica las ideas principales del texto.</li>
<li style="text-align: justify;">Comprende la información trabajada.</li>
<li style="text-align: justify;">Expresión oral y escrita</li>
<li style="text-align: justify;">Explica ideas con claridad.</li>
<li style="text-align: justify;">Utiliza vocabulario adecuado.</li>
</ol>
<p><br />Competencia digital y trabajo cooperativo:</p>
<ol>
<li>Utiliza Canva correctamente.</li>
<li>Navega de forma responsable.</li>
<li>Trabajo cooperativo</li>
<li>Participa activamente.</li>
<li>Respeta las opiniones de los demás.</li>
<li>Colabora con su pareja.</li>
<li>Creatividad</li>
<li>Diseña presentaciones originales y organizadas.</li>
</ol>
</div>]]></htmlView>
          <jsonProperties><![CDATA[{"ideviceId":"idevice-1778235141737-8fyivn1ig","textInfoDurationInput":"","textInfoDurationTextInput":"Duración","textInfoParticipantsInput":"","textInfoParticipantsTextInput":"Agrupamiento","textTextarea":"<p style=\"text-align: justify;\"><strong>8. CRITERIOS DE EVALUACIÓN</strong></p>\n<p style=\"text-align: justify;\"><br />¿Qué se evaluará?</p>\n<ol>\n<li style=\"text-align: justify;\">Comprensión lectora</li>\n<li style=\"text-align: justify;\">Identifica las ideas principales del texto.</li>\n<li style=\"text-align: justify;\">Comprende la información trabajada.</li>\n<li style=\"text-align: justify;\">Expresión oral y escrita</li>\n<li style=\"text-align: justify;\">Explica ideas con claridad.</li>\n<li style=\"text-align: justify;\">Utiliza vocabulario adecuado.</li>\n</ol>\n<p><br />Competencia digital y trabajo cooperativo:</p>\n<ol>\n<li>Utiliza Canva correctamente.</li>\n<li>Navega de forma responsable.</li>\n<li>Trabajo cooperativo</li>\n<li>Participa activamente.</li>\n<li>Respeta las opiniones de los demás.</li>\n<li>Colabora con su pareja.</li>\n<li>Creatividad</li>\n<li>Diseña presentaciones originales y organizadas.</li>\n</ol>","textFeedbackInput":"Mostrar retroalimentación","textFeedbackTextarea":""}]]></jsonProperties>
